# R session / IDE
.Rhistory
.RData
.Rproj.user/
*.Rcheck/

# renv
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/

# Raw data and microdata derivatives (NEVER commit)
data/*.mdb
data/*.accdb
data/*.csv
data/*.rds
data/*.RData
!data/.gitkeep
!data/README.md

# Output artifacts (regenerated on reproduction)
output/*
!output/.gitkeep
tables/*
!tables/.gitkeep
figures/*
!figures/.gitkeep

# Knit byproducts
*.html
*.docx
*.pdf
*_files/
*_cache/

# Dissemination: final poster (PDF) and flash-talk video (MP4) -- intentionally tracked,
# overriding the *.pdf ignore above for this folder only.
!poster_and_video/*.pdf
!poster_and_video/*.mp4

# Word lock files
~$*.docx
~$*.doc

# OS junk
Thumbs.db
.DS_Store
desktop.ini

# Editor / local
.vscode/
.idea/
*.swp
.spotify_cache
.env
.env.*
*.key
*.pem

# Reference material (further reading) -- override the *.pdf ignore for this folder
!further_reading/*.pdf
!further_reading/*.mp4
!further_reading/*.md
